# Acta headless service / MCP configuration — copy to .env and fill in.
# (.env is gitignored.)

# Path to the SQLite DB the desktop app uses. Set explicitly to be safe.
# macOS default:
ACTA_DB_PATH="$HOME/Library/Application Support/io.github.qiaoxu123.acta/acta.db"

# HTTP service bind
ACTA_PORT=8787
ACTA_HOST=127.0.0.1

# Optional bearer token. If set, all endpoints except /health require it.
ACTA_API_TOKEN=

# AI ingest (email/text -> structured records) via Claude
ANTHROPIC_API_KEY=
ACTA_AI_MODEL=claude-sonnet-4-6

# MCP server -> HTTP API location
ACTA_API_URL=http://127.0.0.1:8787
